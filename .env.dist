# Nexdoz production environment — copy to .env on the droplet and fill in.
#
# Secrets MUST NOT be committed. .env is gitignored.
# Generate random secrets with: openssl rand -hex 32

########################################
# Public-facing hostnames + TLS
########################################

# Root domain you own; Caddy will request certs for api.${DOMAIN} and app.${DOMAIN}
DOMAIN=nexdoz.example

# Email used by Let's Encrypt for cert expiry notifications
CADDY_EMAIL=ops@nexdoz.example

########################################
# Image versions (bump to deploy new releases)
########################################

USER_API_VERSION=v0.3.1
WEB_VERSION=v0.2.0

########################################
# Postgres
########################################

POSTGRES_DB=nexdoz
POSTGRES_USER=nexdoz
# openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_32_BYTE_HEX

########################################
# Application secrets (CHANGE EVERY ONE)
########################################

# openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX

# openssl rand -hex 32
JWT_SECRET=CHANGE_ME_32_BYTE_HEX

# openssl rand -hex 32
AUTH_SECRET=CHANGE_ME_32_BYTE_HEX

########################################
# Logging (stdout for internal test; betterstack for beta)
########################################

LOGGER_SINK=stdout
LOGGER_LEVEL=info
LOGGER_BETTERSTACK_SOURCE_TOKEN=
LOGGER_BETTERSTACK_ENDPOINT=

########################################
# AI providers (all optional — leave empty unless wiring a specific tier)
########################################

AI_PROVIDER=
AI_PROVIDER_DEFAULT=
AI_PROVIDER_CORE=
AI_PROVIDER_PLUS=
AI_PROVIDER_CLINICIAN=
AI_PROVIDER_ENTERPRISE=

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=

ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
CLAUDE_MODEL=
